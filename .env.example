# Copiez ce fichier en .env et remplissez vos clés (usage personnel / serveur local).
# NE COMMITTEZ JAMAIS le fichier .env sur GitHub.

# Hugging Face — images Fiction Studio (gratuit avec crédits mensuels)
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_votre_token_ici

# Mistral — planification de scènes (gratuit Free Tier)
# https://console.mistral.ai
MISTRAL_API_KEY=votre_cle_mistral_ici

# FAL — optionnel (modes text-to-video / Remix IA uniquement)
# FAL_KEY=fal_votre_cle_ici

# Installation npm sans Python (Windows)
# YOUTUBE_DL_SKIP_PYTHON_CHECK=1
