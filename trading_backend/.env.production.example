POSTGRES_DB=trading_ai
POSTGRES_USER=trading_app
POSTGRES_PASSWORD=replace-with-a-long-random-password

AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_TOKEN_EXPIRY_MINUTES=120

DOMAIN=trading.example.com
ACME_EMAIL=admin@example.com

NEWS_INTERVAL_SECONDS=5
RUNTIME_RECOVERY_DELAY_SECONDS=2
WATCHDOG_INTERVAL_SECONDS=10
LOG_LEVEL=INFO

# Public app URL used by payment/OAuth callbacks
PUBLIC_BASE_URL=https://trading.example.com

# Payment provider - Stripe Checkout
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=eur
STRIPE_SUCCESS_URL=https://trading.example.com/ui?payment=success
STRIPE_CANCEL_URL=https://trading.example.com/ui?payment=cancel

# OAuth login - Google Cloud
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Crypto brokers/exchanges - restricted API keys only
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Stocks/ETF brokers
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
IBKR_GATEWAY_URL=
